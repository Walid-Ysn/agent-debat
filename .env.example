# LLM — Ollama local
OLLAMA_MODEL=qwen3:8b
OLLAMA_URL=http://localhost:11434

# JWT auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Embedding model (small for faster first run)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Database fallback (local)
DATABASE_URL=sqlite:///./agent_debat.db

# Supabase (recommended in production)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require
