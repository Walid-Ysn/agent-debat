# LLM — Ollama local
OLLAMA_MODEL=qwen3:8b
OLLAMA_URL=http://localhost:11434

# Embedding model (small for faster first run)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Database fallback (local)
